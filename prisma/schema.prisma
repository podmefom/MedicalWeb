generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Doctor {
  id           String        @id @default(cuid())
  name         String
  specialty    String
  experience   Int
  bio          String
  image        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]

  @@index([specialty])
}

model Appointment {
  id            String   @id @default(cuid())
  patientName   String
  patientPhone  String
  patientEmail  String?
  date          DateTime
  doctorId      String
  doctor        Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  status        String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED, COMPLETED
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([doctorId])
  @@index([date])
  @@index([status])
}